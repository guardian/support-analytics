{
	"name": "super-mode-calculator",
	"version": "1.0.0",
	"license": "MIT",
	"private": true,
	"isAwsLambda": true,
	"cloudformation": "../cfn.yaml",
	"projectName": "Support::super-mode-calculator",
	"buildDir": "./target",
	"riffraffFile": "./riff-raff.yaml",
	"description": "Super mode calculator step functions",
	"scripts": {
		"lint": "eslint '*/**/*.ts'",
		"build": "esbuild src/lambda.ts --bundle --platform=node --outfile=target/lambda.js --external:@aws-sdk/*",
		"local": "STAGE=CODE AthenaOutputBucket=gu-support-analytics SchemaName=acquisition AWS_PROFILE=membership ts-node src/local/run.ts"
	},
	"devDependencies": {
		"@guardian/eslint-config": "^14.0.0",
		"@guardian/prettier": "^2.1.5",
		"@types/node": "^22.10.6",
		"eslint": "^9.39.1",
		"@guardian/prettier": "^10.0.0",
		"ts-node": "^10.9.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@aws-sdk/client-dynamodb": "^3.995.0",
		"@aws-sdk/client-ssm": "^3.995.0",
		"@aws-sdk/lib-dynamodb": "^3.995.0",
		"@google-cloud/bigquery": "8.1.1",
		"date-fns": "^4.1.0",
		"esbuild": "^0.27.3",
		"google-auth-library": "^10.6.1",
		"zod": "^4.3.6"
	},
	"packageManager": "pnpm@8.15.7"
}
